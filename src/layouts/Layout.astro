---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Blog de Ingeniería de Datos e Inteligencia Artificial" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body>
		<header class="navbar">
			<div class="container">
				<a href="/" class="logo">Data<span>AI</span>_UNIR</a>
				<nav>
					<a href="/">Inicio</a>
				</nav>
			</div>
		</header>
		
		<main class="container">
			<slot />
		</main>

		<footer>
			<p>&copy; {new Date().getFullYear()} blog-unir. Especialidad en Datos e IA.</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--primary: #00bcd4;
		--bg-dark: #0f172a;
		--card-bg: #1e293b;
		--text-light: #f8fafc;
		--text-muted: #94a3b8;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: system-ui, -apple-system, sans-serif;
		background-color: var(--bg-dark);
		color: var(--text-light);
		line-height: 1.7;
	}

	.container {
		max-width: 850px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.navbar {
		background-color: var(--card-bg);
		padding: 20px 0;
		border-bottom: 1px solid #334155;
		margin-bottom: 40px;
	}

	.navbar .container {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		font-size: 1.4rem;
		font-weight: 700;
		text-decoration: none;
		color: var(--text-light);
		letter-spacing: 0.5px;
	}

	.logo span {
		color: var(--primary);
	}

	nav a {
		text-decoration: none;
		color: var(--text-light);
		font-weight: 500;
	}

	nav a:hover {
		color: var(--primary);
	}

	footer {
		text-align: center;
		padding: 40px 20px;
		margin-top: 60px;
		color: var(--text-muted);
		font-size: 0.9rem;
		border-top: 1px solid #334155;
	}
</style>